{
    "python.analysis.extraPaths": ["./src"],
    "python.analysis.updateImportsOnFileMove.enabled": true,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 5,
    "workbench.editor.limit.perEditorGroup": true,
    "editor.smoothScrolling": true,             // 核心：让所有滚动（包括键盘）带上平滑过渡
  "editor.cursorSmoothCaretAnimation": "on",  // 让光标移动也像温润的玉石一样滑动
}